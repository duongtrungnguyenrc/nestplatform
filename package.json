    "@nestjs/platform-express": "^11.1.17",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "commitlint": "^20.5.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lerna": "^9.0.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "reflect-metadata": "^0.2.2",
