{
  "name": "feign-example",
  "version": "1.0.0",
  "description": "Example project demonstrating @nestplatform/feign with both fetch and feign modes",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:mock": "npx json-server --watch db.json --port 3001",
    "start:all": "concurrently \"npm run start:mock\" \"sleep 2 && npm run start:dev\""
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestplatform/common": "^1.0.1",
    "@nestplatform/feign": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/node": "^22.10.7",
    "json-server": "^0.17.4",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}